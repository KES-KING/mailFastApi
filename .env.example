# =========================
# SMTP (provider connection)
# =========================
# SMTP hostname or IP (required in real environments)
SMTP_HOST=
# Common ports: 587 (STARTTLS), 465 (implicit TLS)
SMTP_PORT=587
# SMTP auth username (provider dependent)
SMTP_USER=
# SMTP auth password / app password (provider dependent)
SMTP_PASS=
# true for implicit TLS (usually 465), false for STARTTLS/plain connect (usually 587)
SMTP_SECURE=false

# =========================
# SMTP pooling and throughput
# =========================
# Max open SMTP connections in pool
SMTP_MAX_CONNECTIONS=5
# Max messages per connection before recycle
SMTP_MAX_MESSAGES=100
# Max messages allowed in RATE_DELTA window
SMTP_RATE_LIMIT=10
# Window for SMTP_RATE_LIMIT in milliseconds
SMTP_RATE_DELTA=1000

# =========================
# API server
# =========================
PORT=3000
# Optional "from" sender address. Fallback: SMTP_USER -> no-reply@mailfastapi.local
MAIL_FROM=

# =========================
# Authentication
# =========================
# jwt | api_key | none
AUTH_MODE=jwt

# JWT signing secret (required for AUTH_MODE=jwt)
JWT_SECRET=change_me_with_a_long_random_secret
# JWT issuer/audience must match issue+verify sides
JWT_ISSUER=mailFastApi
JWT_AUDIENCE=mailfastapi-clients
# Token lifetime (examples: 5m, 15m, 1h)
JWT_EXPIRES_IN=5m

# Single default client credentials (jwt mode)
AUTH_CLIENT_ID=webapp-default
AUTH_CLIENT_SECRET=change_me_client_secret

# Optional multi-client JSON. Example:
# [{"clientId":"site-a","clientSecret":"secret-a","scopes":["mail:send"]}]
JWT_CLIENTS_JSON=

# Token endpoint rate limit
TOKEN_RATE_LIMIT_WINDOW_MS=60000
TOKEN_RATE_LIMIT_MAX=30

# API key value (required when AUTH_MODE=api_key)
API_KEY=

# =========================
# Global API rate limiter
# =========================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# =========================
# Queue and worker behavior
# =========================
# Queue backend: redis | memory (tests/dev)
QUEUE_BACKEND=redis
# Max in-memory queued jobs (used when QUEUE_BACKEND=memory)
QUEUE_MAX_SIZE=50000
# Number of parallel worker runners
WORKER_CONCURRENCY=2
# SMTP send attempts per job (including first attempt)
RETRY_ATTEMPTS=3
# Base retry delay in milliseconds (linear by attempt index)
RETRY_DELAY_MS=250
# Graceful shutdown drain timeout in milliseconds
SHUTDOWN_TIMEOUT_MS=20000

# =========================
# Redis mail queue (used when QUEUE_BACKEND=redis)
# =========================
REDIS_URL=redis://127.0.0.1:6379
REDIS_QUEUE_KEY=mailfastapi:mail_jobs
REDIS_COMMAND_TIMEOUT_MS=5000

# =========================
# Logging and storage
# =========================
# SQLite database path for structured system logs
LOG_DB_PATH=data/mailfastapi.sqlite
# Directory for JSONL/file logs
LOG_DIR=logs
# Main file log name
LOG_FILE_NAME=system.log
# Logger flush interval (buffer -> file/sqlite)
LOG_FLUSH_INTERVAL_MS=300

# =========================
# Test-only
# =========================
# Real recipient for: npm test mailsend
TEST_MAIL_TO=
